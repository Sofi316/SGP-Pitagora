# Configuración del servidor de correos (SMTP/IMAP)
MAIL_USERNAME=correo-corporativo@cliente.com
MAIL_PASSWORD=clave-de-aplicacion-segura

# Clave de firma para tokens de seguridad (Mínimo 32 caracteres aleatorios)
JWT_SECRET_KEY=cambiar_por_una_cadena_secreta_muy_larga_en_produccion

# Credenciales de la Base de Datos de Producción (Supabase o Local)
DB_URL=jdbc:postgresql://host-de-produccion:5432/postgres?sslmode=require
DB_USERNAME=usuario_bd_produccion
DB_PASSWORD=clave_bd_produccion

# Conexión al almacenamiento de archivos (Supabase Bucket)
SUPABASE_URL=https://proyecto-cliente.supabase.co
SUPABASE_SERVICE_KEY=llave_de_servicio_de_produccion

# Credenciales del Administrador Inicial del Sistema
ADMIN_INIT_EMAIL=admin@sistemapitagora.cl
ADMIN_INIT_PASSWORD=ClaveInicialSegura2026*
ADMIN_INIT_RUT=11111111-1